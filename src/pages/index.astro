---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="hero">
    <h1>
      Your next idea,<br />
      <span class="serif">shipped with confidence.</span>
    </h1>
    <p>
      MX+C builds practical AI systems for teams with high standards and limited time.
      You bring the problem. We deliver software that works.
    </p>
    <div class="cta-row">
      <a class="button primary" href="/about#contact">Start a conversation</a>
      <a class="button secondary" href="/docs">Read the docs</a>
    </div>
  </section>

  <section class="grid">
    <article class="card">
      <h2>Applied AI Engineering</h2>
      <p>We convert ambiguous ideas into production-quality AI products.</p>
    </article>
    <article class="card">
      <h2>Lean Delivery</h2>
      <p>Small team, rapid iterations, and transparent weekly outcomes.</p>
    </article>
    <article class="card">
      <h2>Research to Reality</h2>
      <p>Academic depth with pragmatic implementation decisions.</p>
    </article>
  </section>
</BaseLayout>
